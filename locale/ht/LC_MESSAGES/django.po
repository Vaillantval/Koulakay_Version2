#: templates/pages/home.html:290
msgid ""
"\n"
"                    Options d'évaluation sécurisées, en ligne et hybrides, "
"pour valider les résultats d'apprentissage et\n"
"                    les compétences, avec des points de service accrédités "
"pour des évaluations en présentiel.\n"
"                    "
msgstr ""
"\n"
"                    Opsyon evalyasyon sekirize, sou entènèt ak ibrid,\n"
"                    pou valide rezilta aprantisaj ak\n"
"                    konpetans, ak pwen sèvis akredite\n"
"                    pou evalyasyon an pèsòn.\n"
"                    "

#: templates/pages/home.html:302
msgid "Activités d'engagement communautaire"
msgstr "Aktivite angajman kominotè"

#: templates/pages/home.html:304
msgid ""
"\n"
"                    Programmes récréatifs et pratiques, tels que des "
"tournois d'échecs en ligne, des initiatives\n"
"                    sportives et des ateliers agricoles, conçus pour "
"compléter l'apprentissage formel.\n"
"                    "
msgstr ""
"\n"
"                    Pwogram rekreyatif ak pratik, tankou tounwa echèk sou entènèt, inisyativ\n"
"                    espòtif ak atelye agrikòl, yo fèt pou\n"
"                    konplete aprantisaj fòmèl.\n"
"                    "

