#: templates/pages/home.html:276
msgid ""
"\n"
"                    Des outils, ressources et formations pour aider les "
"enseignants à perfectionner leurs compétences\n"
"                    pédagogiques et à intégrer la technologie dans leurs "
"pratiques éducatives.\n"
"                    "
msgstr ""
"\n"
"                    Zouti, resous ak fòmasyon pou ede pwofesè yo amelyore konpetans yo\n"
"                    pedagojik ak entegre teknoloji nan\n"
"                    pratik edikatif yo.\n"
"                    "

